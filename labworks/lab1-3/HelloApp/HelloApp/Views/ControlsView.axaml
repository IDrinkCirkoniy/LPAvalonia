<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HelloApp.ViewModels"
             x:DataType="vm:ControlsViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HelloApp.Views.ControlsView">

<DockPanel>
	<TextBlock>
        <Span FontSize="20" Background="LightGray">
            <Bold>
		        <Run Text="Meow" Foreground="Yellow"/>
            </Bold>

            <Italic>
		        <Run Text="Meow" Foreground="Blue"/>
            </Italic>
        </Span>

        <LineBreak/>

        <Underline>
		    <Run Text="Meow" Foreground="Black"/>
        </Underline>

		<Run Text="Meow" Foreground="White"/>

        <InlineUIContainer BaselineAlignment="Baseline">
            <Image Width="32" Height="32" VerticalAlignment="Top" Source="/Assets/avalonia-logo.ico"/>
        </InlineUIContainer>

        <InlineUIContainer>
			<Button Content="Meow"/>
        </InlineUIContainer>
    </TextBlock>
</DockPanel>
</UserControl>
