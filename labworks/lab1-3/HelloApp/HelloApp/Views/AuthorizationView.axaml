<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HelloApp.ViewModels"
             x:DataType="vm:AuthorizationViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HelloApp.Views.AuthorizationView">
    <StackPanel>
		<StackPanel HorizontalAlignment="Center">
			<Label Content="Логин"/>
            <TextBox Watermark="Введите логин"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center">
			<Label Content="Пароль"/>
            <TextBox Watermark="Введите логин"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center">
			<Button Content="Зарегистрироваться" Command="{Binding EnterRegistration}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
